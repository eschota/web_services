# Install as /etc/autorig-animation-fitting-telegram.env with mode 0600.
# This is the separate Animation Fitting review bot, not TELEGRAM_BOT_TOKEN.
ANIMATION_FITTING_TELEGRAM_BOT_TOKEN=

# Discover once after the owner sends /start:
# python -m animation_fitting_telegram_bot discover-owner
ANIMATION_FITTING_TELEGRAM_OWNER_CHAT_ID=
ANIMATION_FITTING_TELEGRAM_OWNER_USER_ID=

# Append-only human-decision audit log. Keep outside the git checkout.
ANIMATION_FITTING_TELEGRAM_REVIEW_LEDGER=/var/lib/autorig-animation-fitting/telegram-review.jsonl
