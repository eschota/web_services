[Unit]
Description=AutoRig Online — DB cleanup (gallery dead assets + no-poster rows)
After=network.target

[Service]
Type=oneshot
User=root
Group=root
WorkingDirectory=/root/autorig-online/backend
Environment="PATH=/root/autorig-online/venv/bin"
# Matches backend default: no automatic task row deletion. Override with AUTOMATIC_TASK_DB_DELETION=1 if needed.
Environment=AUTOMATIC_TASK_DB_DELETION=0
ExecStart=/root/autorig-online/venv/bin/python scripts/run_task_cleanup.py
Nice=10

[Install]
WantedBy=multi-user.target
