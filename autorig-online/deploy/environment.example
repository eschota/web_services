# NEW_TASK_PURGE_TASKS_MAX_FREED_GB=8
# MIN_FREE_SPACE_GB=10
# AUTOMATIC_TASK_DB_DELETION=0

RESEND_API_KEY=
# Must be a verified sender/domain in Resend
EMAIL_FROM=noreply@autorig.online
