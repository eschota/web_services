{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://autorig.online/schemas/animation-fitting/tap-export.v1.schema.json",
  "title": "Minimal TAP-style JSON interchange",
  "description": "Array layout is intentionally supplied out-of-band to the adapter and never guessed.",
  "type": "object",
  "additionalProperties": true,
  "required": ["tracks", "occluded"],
  "properties": {
    "tracks": {"type": "array", "minItems": 1},
    "occluded": {"type": "array", "minItems": 1},
    "confidence": {"type": "array"},
    "track_ids": {"type": "array", "minItems": 1},
    "query_frames": {"type": "array"}
  }
}
