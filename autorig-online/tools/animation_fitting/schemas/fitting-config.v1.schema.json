{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://autorig.online/schemas/animation-fitting/fitting-config.v1.schema.json",
  "title": "AutoRig temporal fitting optimizer config v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema"],
  "properties": {
    "schema": {"const": "autorig-fitting-config.v1"},
    "reprojection_weight": {"type": "number", "minimum": 0},
    "depth_weight": {"type": "number", "minimum": 0},
    "silhouette_weight": {"type": "number", "minimum": 0},
    "joint_rest_weight": {"type": "number", "minimum": 0},
    "joint_velocity_weight": {"type": "number", "minimum": 0},
    "joint_acceleration_weight": {"type": "number", "minimum": 0},
    "root_velocity_weight": {"type": "number", "minimum": 0},
    "root_acceleration_weight": {"type": "number", "minimum": 0},
    "contact_height_weight": {"type": "number", "minimum": 0},
    "contact_slide_weight": {"type": "number", "minimum": 0},
    "loop_pose_weight": {"type": "number", "minimum": 0},
    "loop_velocity_weight": {"type": "number", "minimum": 0},
    "robust_loss": {"enum": ["linear", "soft_l1", "huber", "cauchy", "arctan"]},
    "f_scale": {"type": "number", "exclusiveMinimum": 0},
    "max_nfev": {"type": "integer", "minimum": 1},
    "max_variables": {"type": "integer", "minimum": 1},
    "allow_unbounded_joints": {"type": "boolean"},
    "active_bones": {
      "oneOf": [
        {"type": "null"},
        {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}}
      ]
    }
  }
}
