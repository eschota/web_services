{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://autorig.online/schemas/animation-fitting/observations.v1.schema.json",
  "title": "AutoRig fitting observations v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "frame_count", "width", "height", "fps", "tracks"],
  "properties": {
    "schema": {"const": "autorig-fitting-observations.v1"},
    "frame_count": {"type": "integer", "minimum": 1},
    "width": {"type": "integer", "minimum": 1},
    "height": {"type": "integer", "minimum": 1},
    "fps": {"type": "number", "exclusiveMinimum": 0},
    "tracks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "anchor_id", "query_frame", "points"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "anchor_id": {"type": "string", "minLength": 1},
          "query_frame": {"type": "integer", "minimum": 0},
          "points": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["frame", "x", "y", "visible"],
              "properties": {
                "frame": {"type": "integer", "minimum": 0},
                "x": {"type": "number"},
                "y": {"type": "number"},
                "visible": {"type": "boolean"},
                "confidence": {"type": "number", "minimum": 0}
              }
            }
          }
        }
      }
    },
    "silhouettes": {
      "type": "array",
      "default": [],
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["frame", "path"],
        "properties": {
          "frame": {"type": "integer", "minimum": 0},
          "path": {"type": "string", "minLength": 1}
        }
      }
    },
    "depth": {
      "type": "array",
      "default": [],
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["frame", "path", "mode"],
        "properties": {
          "frame": {"type": "integer", "minimum": 0},
          "path": {"type": "string", "minLength": 1},
          "mode": {"enum": ["camera_z", "affine_to_camera_z"]},
          "scale": {"type": "number"},
          "offset": {"type": "number"},
          "invalid_value": {"type": "number"}
        },
        "allOf": [
          {
            "if": {"properties": {"mode": {"const": "affine_to_camera_z"}}},
            "then": {"required": ["scale", "offset"]},
            "else": {"not": {"anyOf": [{"required": ["scale"]}, {"required": ["offset"]}]}}
          }
        ]
      }
    },
    "contacts": {
      "type": "array",
      "default": [],
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["anchor_id", "frames"],
        "properties": {
          "anchor_id": {"type": "string", "minLength": 1},
          "frames": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {"type": "integer", "minimum": 0}
          },
          "ground_height": {"type": "number"},
          "weight": {"type": "number", "exclusiveMinimum": 0}
        }
      }
    },
    "provenance": {"type": "object"}
  }
}
