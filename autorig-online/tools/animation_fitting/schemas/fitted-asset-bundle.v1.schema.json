{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://autorig.online/schemas/animation-fitting/fitted-asset-bundle.v1.schema.json",
  "title": "AutoRig fitted Blender/FBX/GLB asset bundle v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema", "semantic_action_id", "source", "motion", "target", "blender",
    "timing", "transform_contract", "action", "skin", "cleanup", "fbx_validation", "glb_validation", "artifacts"
  ],
  "properties": {
    "schema": {"const": "autorig-fitted-asset-bundle.v1"},
    "semantic_action_id": {"type": "string", "pattern": "^[a-z][a-z0-9_]{1,63}$"},
    "source": {"$ref": "#/$defs/source"},
    "motion": {
      "type": "object",
      "required": ["path", "sha256", "schema", "input_fps"],
      "properties": {
        "path": {"type": "string"},
        "sha256": {"$ref": "#/$defs/sha"},
        "schema": {"const": "autorig-fitted-animation.v1"},
        "input_fps": {"type": "number", "exclusiveMinimum": 0}
      }
    },
    "target": {"type": "object"},
    "blender": {"type": "object"},
    "timing": {
      "type": "object",
      "required": ["frame_count", "frame_start", "frame_end", "fps", "duration_seconds", "loop"],
      "properties": {
        "frame_count": {"type": "integer", "minimum": 2},
        "frame_start": {"const": 0},
        "frame_end": {"type": "integer", "minimum": 1},
        "fps": {"type": "number", "exclusiveMinimum": 0},
        "duration_seconds": {"type": "number", "exclusiveMinimum": 0},
        "loop": {"type": "boolean"}
      }
    },
    "transform_contract": {"type": "object"},
    "action": {"type": "object"},
    "skin": {"type": "object"},
    "cleanup": {"type": "object"},
    "fbx_validation": {"type": "object"},
    "glb_validation": {"type": "object"},
    "artifacts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["blend", "fbx", "glb"],
      "properties": {
        "blend": {"$ref": "#/$defs/artifact"},
        "fbx": {"$ref": "#/$defs/artifact"},
        "glb": {"$ref": "#/$defs/artifact"}
      }
    }
  },
  "$defs": {
    "sha": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "source": {
      "type": "object",
      "required": ["path", "sha256"],
      "properties": {"path": {"type": "string"}, "sha256": {"$ref": "#/$defs/sha"}}
    },
    "artifact": {
      "type": "object",
      "required": ["filename", "sha256", "bytes"],
      "properties": {
        "filename": {"type": "string", "minLength": 1},
        "sha256": {"$ref": "#/$defs/sha"},
        "bytes": {"type": "integer", "minimum": 1}
      }
    }
  }
}
