{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://autorig.online/schemas/semantic-ltx-profile.v1.schema.json",
  "title": "AutoRig semantic LTX reference profile v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "profile_id",
    "source",
    "limb_groups",
    "palette_linear",
    "gates"
  ],
  "properties": {
    "schema": {
      "const": "autorig-semantic-ltx-profile.v1"
    },
    "profile_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_.-]+$"
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rig_type",
        "filename",
        "sha256",
        "armature_name",
        "mesh_names"
      ],
      "properties": {
        "rig_type": {"type": "string", "minLength": 1},
        "filename": {"type": "string", "minLength": 1},
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "armature_name": {"type": "string", "minLength": 1},
        "mesh_names": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        }
      }
    },
    "limb_groups": {
      "type": "object",
      "additionalProperties": false,
      "required": ["fore_left", "fore_right", "hind_left", "hind_right"],
      "properties": {
        "fore_left": {"$ref": "#/$defs/foreLeft"},
        "fore_right": {"$ref": "#/$defs/foreRight"},
        "hind_left": {"$ref": "#/$defs/hindLeft"},
        "hind_right": {"$ref": "#/$defs/hindRight"}
      }
    },
    "palette_linear": {
      "type": "object",
      "additionalProperties": false,
      "required": ["body", "fore_near", "fore_far", "hind_near", "hind_far"],
      "properties": {
        "body": {"$ref": "#/$defs/color"},
        "fore_near": {"$ref": "#/$defs/color"},
        "fore_far": {"$ref": "#/$defs/color"},
        "hind_near": {"$ref": "#/$defs/color"},
        "hind_far": {"$ref": "#/$defs/color"}
      }
    },
    "gates": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "minimum_face_limb_weight",
        "minimum_face_dominance",
        "minimum_faces_per_source_group",
        "minimum_group_weight_mass",
        "minimum_near_far_depth_separation",
        "minimum_pixels_per_output_label",
        "minimum_pixel_fraction_of_mask",
        "maximum_mask_mismatch_pixels",
        "mask_threshold",
        "pixel_color_tolerance",
        "minimum_palette_distance"
      ],
      "properties": {
        "minimum_face_limb_weight": {"type": "number", "exclusiveMinimum": 0, "maximum": 1},
        "minimum_face_dominance": {"type": "number", "exclusiveMinimum": 0, "maximum": 1},
        "minimum_faces_per_source_group": {"type": "integer", "minimum": 1},
        "minimum_group_weight_mass": {"type": "number", "exclusiveMinimum": 0},
        "minimum_near_far_depth_separation": {"type": "number", "exclusiveMinimum": 0},
        "minimum_pixels_per_output_label": {"type": "integer", "minimum": 1},
        "minimum_pixel_fraction_of_mask": {"type": "number", "exclusiveMinimum": 0, "maximum": 1},
        "maximum_mask_mismatch_pixels": {"type": "integer", "minimum": 0},
        "mask_threshold": {"type": "number", "exclusiveMinimum": 0, "maximum": 1},
        "pixel_color_tolerance": {"type": "number", "exclusiveMinimum": 0, "maximum": 1},
        "minimum_palette_distance": {"type": "number", "exclusiveMinimum": 0}
      }
    }
  },
  "$defs": {
    "color": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": {"type": "number", "minimum": 0, "maximum": 1}
    },
    "bones": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    },
    "foreLeft": {
      "type": "object",
      "additionalProperties": false,
      "required": ["anatomy", "side", "bones"],
      "properties": {
        "anatomy": {"const": "fore"},
        "side": {"const": "left"},
        "bones": {"$ref": "#/$defs/bones"}
      }
    },
    "foreRight": {
      "type": "object",
      "additionalProperties": false,
      "required": ["anatomy", "side", "bones"],
      "properties": {
        "anatomy": {"const": "fore"},
        "side": {"const": "right"},
        "bones": {"$ref": "#/$defs/bones"}
      }
    },
    "hindLeft": {
      "type": "object",
      "additionalProperties": false,
      "required": ["anatomy", "side", "bones"],
      "properties": {
        "anatomy": {"const": "hind"},
        "side": {"const": "left"},
        "bones": {"$ref": "#/$defs/bones"}
      }
    },
    "hindRight": {
      "type": "object",
      "additionalProperties": false,
      "required": ["anatomy", "side", "bones"],
      "properties": {
        "anatomy": {"const": "hind"},
        "side": {"const": "right"},
        "bones": {"$ref": "#/$defs/bones"}
      }
    }
  }
}
